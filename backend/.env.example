# Backend local environment example

# Enable/disable LLM-powered extraction and explanation
ENABLE_LLM=false

# DeepSeek / OpenAI-compatible endpoint config
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Sandbox URL for local non-docker backend runs
SANDBOX_URL=http://127.0.0.1:18080
